---
import { Send } from "@lucide/astro";

interface Props {
  title: string;
  photo?: string;
  Content: any;
}

const { title, photo, Content } = Astro.props;
---

<section id="about" class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
        
        <div class="card bg-base-900 shadow-sm flex-col lg:flex-row lg:gap-6">
            
            {
                photo && (
                    <figure class="shrink-0 w-full lg:w-48"> 
                        <img 
                            src={photo} 
                            alt={title} 
                            
                            class="w-100 h-60 lg:h-full object-cover rounded-t-2xl lg:rounded-l-2xl lg:rounded-r-none lg:rounded-t-none" 
                        />
                    </figure>
                )
            }
            
            <div class="card-body rounded-b-2xl lg:rounded-r-2xl lg:rounded-l-none lg:rounded-b-none">
                <h2 class="card-title text-2xl">{title}</h2>
                <p class="text-lg">
                    <Content />
                </p>
                </div>
        </div>
    </div>
</section>
